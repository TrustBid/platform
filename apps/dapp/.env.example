# URL del backend (API REST).
# Local dev: http://localhost:3001 (default automático si NODE_ENV=development)
# Producción (Railway):
# NEXT_PUBLIC_API_URL=https://api-production-9557.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# Privy — App ID PÚBLICO (client). Crear app en dashboard.privy.io y completar.
# Sin esto, el login con email/OTP no aparece (y en prod loguea un error visible).
NEXT_PUBLIC_PRIVY_APP_ID=

# Red Stellar para el indicador / Horizon
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
