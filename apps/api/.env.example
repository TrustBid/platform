# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/trustbid?sslmode=require

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# ── Stellar / Soroban ─────────────────────────────────────────────────────────
# Rede Stellar: testnet | public (mainnet Horizon) — SorobanService aceita `public` ou `mainnet` como mainnet
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# RPC Soroban (SorobanService usa STELLAR_RPC_URL; alias legado abaixo)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Keypair del servidor para firmar challenges SEP-10 y txs Soroban (NUNCA exponer al cliente)
STELLAR_SERVER_SECRET=SXXX...
STELLAR_SERVER_PUBLIC_KEY=GXXX...
# IDs de contratos deployados (testnet) — ver caatinga.artifacts.json o `caatinga deploy`
FUND_TRACKER_CONTRACT_ID=CC6OJ26655KKLDZB6HXBV2IN4WWU7GMU57IX7WQSF3SKAEJRMAPQVHYS
EXPENSE_ANCHOR_CONTRACT_ID=CABW2KK4CRLHOB4GATGIT2MDGE3HLTDTI5YZOFOQHGLONQTNU3MYYOAW
SBT_BADGE_CONTRACT_ID=CCBTM23SCCOEA7Y55DL4ENJNWID7OATWB7RXHAS7MD6CQHW3PMG4CDNK

# ── AWS KMS (firma server-side de txs Stellar) ────────────────────────────────
AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:xxx:key/xxx
AWS_REGION=us-east-1

# ── Cloudflare R2 (evidencias, PDFs, artefactos ZK) ──────────────────────────
R2_BUCKET=trustbid-evidencias
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx

# ── SDP (Stellar Disbursement Platform) ──────────────────────────────────────
SDP_BASE_URL=https://sdp.trustbid.com

# ── Privy (riel auth/wallet embebida para usuarios no nativos cripto) ─────────
# Crear app en dashboard.privy.io (sandbox) y completar. La wallet Stellar es
# Tier 2 (rawSign) — validar en sandbox antes de prod. NUNCA exponer el secret.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=8h

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
