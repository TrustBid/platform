# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/trustbid?sslmode=require

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# ── Stellar / Soroban ─────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Keypair del servidor para firmar challenges SEP-10 (NUNCA exponer al cliente)
STELLAR_SERVER_SECRET=SXXX...
# Public key del servidor (derivado del secret). Se usa como fallback de caller en txs on-chain.
STELLAR_SERVER_PUBLIC_KEY=GAOJ53SVIVOVP4O376PZBPTZRWHC5ML5JV4PSV26GT56MQSRR2J25EQO

# ── Contratos Soroban ──────────────────────────────────────────────────────────
# Identificadores de los contratos smart desplegados. Requeridos para operaciones on-chain.
FUND_TRACKER_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPENSE_ANCHOR_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SBT_BADGE_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── AWS KMS (firma server-side de txs Stellar) ────────────────────────────────
AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:xxx:key/xxx
AWS_REGION=us-east-1

# ── Cloudflare R2 (evidencias, PDFs, artefactos ZK) ──────────────────────────
R2_BUCKET=trustbid-evidencias
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx

# ── SDP (Stellar Disbursement Platform) ──────────────────────────────────────
SDP_BASE_URL=https://sdp.trustbid.com

# ── Privy (riel auth/wallet embebida para usuarios no nativos cripto) ─────────
# Crear app en dashboard.privy.io (sandbox) y completar. La wallet Stellar es
# Tier 2 (rawSign) — validar en sandbox antes de prod. NUNCA exponer el secret.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=8h

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
