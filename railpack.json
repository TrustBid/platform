{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "steps": {
    "setup": {
      "inputs": [{ "local": true }],
      "commands": ["npm install", "npm run build --workspace=apps/api"]
    }
  },
  "deploy": {
    "startCommand": "node apps/api/dist/main.js",
    "inputs": [{ "step": "setup" }]
  }
}
