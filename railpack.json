{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "steps": {
    "build": {
      "inputs": [
        { "step": "install" },
        { "local": true, "include": ["."] }
      ],
      "commands": ["npm run build --workspace=apps/api"]
    }
  },
  "deploy": {
    "startCommand": "node apps/api/dist/main.js"
  }
}
