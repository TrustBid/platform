{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "steps": {
    "install": {
      "inputs": [{ "local": true }],
      "commands": ["npm install"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["npm run build --workspace=apps/api"]
    }
  },
  "deploy": {
    "startCommand": "node apps/api/dist/main.js"
  }
}
