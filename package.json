{
  "name": "trustbid-platform",
  "version": "0.0.1",
  "description": "TrustBid Platform — fund transparency & traceability for NGOs on Stellar blockchain",
  "author": "TrustBid Team",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/TrustBid/platform"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "dev:dapp": "turbo dev --filter=@trustbid/dapp",
    "dev:api": "turbo dev --filter=@trustbid/api",
    "dev:landing": "turbo dev --filter=@trustbid/landing"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5",
    "prettier": "^3",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.12.1"
}
